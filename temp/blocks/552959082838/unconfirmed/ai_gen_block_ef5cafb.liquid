{% doc %}
  @prompt
    Create a Shopify section that acts as a visual divider between other sections on the page. It should be fully customizable with every possible option.
    Divider styles: Include a setting to choose the divider type from the following options: solid line, dashed line, dotted line, double line, wavy line, zigzag line, diagonal slash pattern, and a fully invisible spacer with no visible element.
    Size & spacing: Adjustable divider height or thickness in pixels. Individual top padding and bottom padding controls for the space above and below the divider. Full section height control for when used as a pure spacer.
    Color & gradient: Solid color picker for the divider line. Toggle to switch to gradient mode with two color pickers for gradient start and end color and a gradient angle control from 0 to 360 degrees. Section background color picker with the same solid or gradient toggle so the background behind the divider can also be styled independently.
    Decorative shape dividers: Include an option to choose a decorative SVG shape divider instead of a line — options should include: gentle wave, sharp wave, slanted cut, curve, triangle peak, and soft cloud shape. The shape divider should sit at the top or bottom of the section with a toggle to choose which side. Include a color picker for the shape fill color and an option to flip the shape horizontally or vertically.
    Opacity & visibility: Opacity slider from 0 to 100 percent for the divider element. Separate visibility toggles for desktop and mobile so the divider can be hidden on one device type and shown on the other.
    Width: Divider width control as a percentage of the section width (from 10 percent to 100 percent) and an alignment option (left, center, right) for when the divider is narrower than full width.
    Make the section lightweight, with no unnecessary markup, and ensure all settings are clearly labeled and organized in the Shopify theme editor sidebar.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-divider-section-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: {{ block.settings.section_bg_color }};
    {% if block.settings.section_use_gradient %}
      background: linear-gradient({{ block.settings.section_gradient_angle }}deg, {{ block.settings.section_gradient_start }} 0%, {{ block.settings.section_gradient_end }} 100%);
    {% endif %}
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    {% if block.settings.divider_type == 'spacer' %}
      height: {{ block.settings.spacer_height }}px;
    {% endif %}
    {% unless block.settings.show_on_desktop %}
      display: none;
    {% endunless %}
  }

  .ai-divider-container-{{ ai_gen_id }} {
    width: {{ block.settings.divider_width }}%;
    margin: 0 auto;
    {% if block.settings.divider_alignment == 'left' %}
      margin-left: 0;
      margin-right: auto;
    {% elsif block.settings.divider_alignment == 'right' %}
      margin-left: auto;
      margin-right: 0;
    {% endif %}
    opacity: {{ block.settings.opacity | divided_by: 100.0 }};
  }

  .ai-divider-line-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.divider_thickness }}px;
    background-color: {{ block.settings.divider_color }};
    {% if block.settings.use_gradient %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_start }} 0%, {{ block.settings.gradient_end }} 100%);
    {% endif %}
    border: none;
    margin: 0;
    {% if block.settings.divider_type == 'solid' %}
      border-top: {{ block.settings.divider_thickness }}px solid;
      border-image-source: {% if block.settings.use_gradient %}linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_start }} 0%, {{ block.settings.gradient_end }} 100%){% else %}none{% endif %};
      border-image-slice: 1;
      height: 0;
    {% elsif block.settings.divider_type == 'dashed' %}
      border-top: {{ block.settings.divider_thickness }}px dashed {{ block.settings.divider_color }};
      height: 0;
      background: none;
    {% elsif block.settings.divider_type == 'dotted' %}
      border-top: {{ block.settings.divider_thickness }}px dotted {{ block.settings.divider_color }};
      height: 0;
      background: none;
    {% elsif block.settings.divider_type == 'double' %}
      border-top: {{ block.settings.divider_thickness }}px double {{ block.settings.divider_color }};
      height: 0;
      background: none;
    {% elsif block.settings.divider_type == 'wavy' %}
      height: {{ block.settings.divider_thickness }}px;
      background-image: url("data:image/svg+xml,%3Csvg width='100' height='20' viewBox='0 0 100 20' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 10 Q 12.5 0, 25 10 T 50 10 T 75 10 T 100 10' stroke='{{ block.settings.divider_color | remove: '#' }}' stroke-width='{{ block.settings.divider_thickness }}' fill='none'/%3E%3C/svg%3E");
      background-repeat: repeat-x;
      background-size: 100px {{ block.settings.divider_thickness }}px;
      background-position: center;
    {% elsif block.settings.divider_type == 'zigzag' %}
      height: {{ block.settings.divider_thickness | times: 2 }}px;
      background-image: url("data:image/svg+xml,%3Csvg width='40' height='20' viewBox='0 0 40 20' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 20 L 20 0 L 40 20' stroke='{{ block.settings.divider_color | remove: '#' }}' stroke-width='{{ block.settings.divider_thickness }}' fill='none'/%3E%3C/svg%3E");
      background-repeat: repeat-x;
      background-size: 40px {{ block.settings.divider_thickness | times: 2 }}px;
      background-position: center;
    {% elsif block.settings.divider_type == 'diagonal' %}
      height: {{ block.settings.divider_thickness | times: 3 }}px;
      background-image: repeating-linear-gradient(
        45deg,
        {{ block.settings.divider_color }},
        {{ block.settings.divider_color }} {{ block.settings.divider_thickness }}px,
        transparent {{ block.settings.divider_thickness }}px,
        transparent {{ block.settings.divider_thickness | times: 2 }}px
      );
    {% endif %}
  }

  .ai-divider-shape-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
    {% if block.settings.shape_position == 'top' %}
      top: 0;
    {% else %}
      bottom: 0;
    {% endif %}
    {% if block.settings.shape_flip_vertical %}
      transform: scaleY(-1);
    {% endif %}
    {% if block.settings.shape_flip_horizontal %}
      transform: scaleX(-1);
    {% endif %}
    {% if block.settings.shape_flip_vertical and block.settings.shape_flip_horizontal %}
      transform: scale(-1, -1);
    {% endif %}
  }

  .ai-divider-shape-{{ ai_gen_id }} svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 60px;
  }

  .ai-divider-shape-{{ ai_gen_id }} .ai-shape-fill-{{ ai_gen_id }} {
    fill: {{ block.settings.shape_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-divider-section-{{ ai_gen_id }} {
      {% unless block.settings.show_on_mobile %}
        display: none;
      {% endunless %}
    }
  }

  @media screen and (min-width: 750px) {
    .ai-divider-section-{{ ai_gen_id }} {
      {% unless block.settings.show_on_desktop %}
        display: none;
      {% endunless %}
    }
  }
{% endstyle %}

<div class="ai-divider-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.divider_type != 'spacer' %}
    {% if block.settings.divider_type == 'shape' %}
      <div class="ai-divider-shape-{{ ai_gen_id }}">
        {% if block.settings.shape_style == 'wave_gentle' %}
          <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="ai-shape-fill-{{ ai_gen_id }}"></path>
          </svg>
        {% elsif block.settings.shape_style == 'wave_sharp' %}
          <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M0,0V46.29c47.79,22.2,103.59,32.17,158,28,70.36-5.37,136.33-33.31,206.8-37.5C438.64,32.43,512.34,53.67,583,72.05c69.27,18,138.3,24.88,209.4,13.08,36.15-6,69.85-17.84,104.45-29.34C989.49,25,1113-14.29,1200,52.47V0Z" class="ai-shape-fill-{{ ai_gen_id }}"></path>
          </svg>
        {% elsif block.settings.shape_style == 'slant' %}
          <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M1200 120L0 16.48 0 0 1200 0 1200 120z" class="ai-shape-fill-{{ ai_gen_id }}"></path>
          </svg>
        {% elsif block.settings.shape_style == 'curve' %}
          <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M600,112.77C268.63,112.77,0,65.52,0,7.23V120H1200V7.23C1200,65.52,931.37,112.77,600,112.77Z" class="ai-shape-fill-{{ ai_gen_id }}"></path>
          </svg>
        {% elsif block.settings.shape_style == 'triangle' %}
          <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M598.97 114.72L0 0 0 120 1200 120 1200 0 598.97 114.72z" class="ai-shape-fill-{{ ai_gen_id }}"></path>
          </svg>
        {% elsif block.settings.shape_style == 'cloud' %}
          <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
            <path d="M985.66,92.83C906.67,72,823.78,31,743.84,14.19c-82.26-17.34-168.06-16.33-250.45.39-57.84,11.73-114,31.07-172,41.86A600.21,600.21,0,0,1,0,27.35V120H1200V95.8C1132.19,118.92,1055.71,111.31,985.66,92.83Z" class="ai-shape-fill-{{ ai_gen_id }}"></path>
          </svg>
        {% endif %}
      </div>
    {% else %}
      <div class="ai-divider-container-{{ ai_gen_id }}">
        <div class="ai-divider-line-{{ ai_gen_id }}"></div>
      </div>
    {% endif %}
  {% endif %}
</div>

{% schema %}
{
  "name": "Divider",
  "tag": null,
  "class": "shopify-section-divider",
  "settings": [
    {
      "type": "header",
      "content": "Divider style"
    },
    {
      "type": "select",
      "id": "divider_type",
      "label": "Type",
      "options": [
        {
          "value": "solid",
          "label": "Solid line"
        },
        {
          "value": "dashed",
          "label": "Dashed line"
        },
        {
          "value": "dotted",
          "label": "Dotted line"
        },
        {
          "value": "double",
          "label": "Double line"
        },
        {
          "value": "wavy",
          "label": "Wavy line"
        },
        {
          "value": "zigzag",
          "label": "Zigzag line"
        },
        {
          "value": "diagonal",
          "label": "Diagonal slash pattern"
        },
        {
          "value": "shape",
          "label": "Decorative shape"
        },
        {
          "value": "spacer",
          "label": "Invisible spacer"
        }
      ],
      "default": "solid"
    },
    {
      "type": "select",
      "id": "shape_style",
      "label": "Shape style",
      "info": "Only applies when type is set to decorative shape",
      "options": [
        {
          "value": "wave_gentle",
          "label": "Gentle wave"
        },
        {
          "value": "wave_sharp",
          "label": "Sharp wave"
        },
        {
          "value": "slant",
          "label": "Slanted cut"
        },
        {
          "value": "curve",
          "label": "Curve"
        },
        {
          "value": "triangle",
          "label": "Triangle peak"
        },
        {
          "value": "cloud",
          "label": "Soft cloud"
        }
      ],
      "default": "wave_gentle"
    },
    {
      "type": "select",
      "id": "shape_position",
      "label": "Shape position",
      "info": "Only applies to decorative shapes",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "top"
    },
    {
      "type": "checkbox",
      "id": "shape_flip_horizontal",
      "label": "Flip shape horizontally",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "shape_flip_vertical",
      "label": "Flip shape vertically",
      "default": false
    },
    {
      "type": "header",
      "content": "Size and spacing"
    },
    {
      "type": "range",
      "id": "divider_thickness",
      "label": "Divider thickness",
      "info": "Does not apply to decorative shapes or invisible spacer",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 2
    },
    {
      "type": "range",
      "id": "spacer_height",
      "label": "Spacer height",
      "info": "Only applies when type is set to invisible spacer",
      "min": 10,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Divider color"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use gradient",
      "info": "Does not apply to dashed, dotted, double, wavy, zigzag, or diagonal dividers",
      "default": false
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Gradient start color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Gradient end color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "deg",
      "default": 90
    },
    {
      "type": "header",
      "content": "Shape color"
    },
    {
      "type": "color",
      "id": "shape_color",
      "label": "Shape fill color",
      "info": "Only applies to decorative shapes",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Section background"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "section_use_gradient",
      "label": "Use gradient background",
      "default": false
    },
    {
      "type": "color",
      "id": "section_gradient_start",
      "label": "Gradient start color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "section_gradient_end",
      "label": "Gradient end color",
      "default": "#f0f0f0"
    },
    {
      "type": "range",
      "id": "section_gradient_angle",
      "label": "Gradient angle",
      "min": 0,
      "max": 360,
      "step": 5,
      "unit": "deg",
      "default": 180
    },
    {
      "type": "header",
      "content": "Opacity and visibility"
    },
    {
      "type": "range",
      "id": "opacity",
      "label": "Divider opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "label": "Show on desktop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Width and alignment"
    },
    {
      "type": "range",
      "id": "divider_width",
      "label": "Divider width",
      "info": "Does not apply to decorative shapes",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "select",
      "id": "divider_alignment",
      "label": "Alignment",
      "info": "Only applies when width is less than 100%",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    }
  ],
  "presets": [
    {
      "name": "Divider"
    }
  ]
}
{% endschema %}