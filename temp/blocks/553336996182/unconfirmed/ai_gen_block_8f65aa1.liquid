{% doc %}
  @prompt
    Create a fully customizable Shopify "How it works" transformation section with 3 step cards displayed side by side on desktop and stacked vertically on mobile.
    Section header: An optional small eyebrow label above the main title with font size, color, letter spacing, and visibility toggle. A large bold main heading below it with font size, color, and weight controls. Both centered.
    Step cards layout: 3 cards in a horizontal row on desktop, stacked vertically on mobile, full width. Gap between cards adjustable separately for desktop and mobile. Cards centered.
    Each card contains:
    A step number badge at the top center — a circle with a number (1, 2, 3). Badge background color picker per step independently. Badge text color picker. Badge size control. Fully round by default.
    An image upload field below the badge — centered inside the card. Image width and height controls in pixels or percentage. Image fit mode selector: contain, cover, or original. Aspect ratio presets: 1:1, 4:3, 16:9, free. Individual top, bottom, left, right padding around the image. Border radius control for the image from sharp to fully round. Border toggle with color picker and thickness control. Box shadow on the image with color, blur, and offset controls. Image object-position control: top, center, bottom, left, right. Image rendering quality option: auto or high.
    A bold card title below the image with font size, color, and weight controls.
    A short description text below the title with font size, color, and line height controls.
    Card styling: Card background color picker. Card border radius control. Card border toggle with color and thickness. Card box shadow toggle with shadow color, blur, and offset. Individual padding controls inside each card on all four sides. Minimum card height option.
    Global image default: A global image size setting applied to all 3 cards at once as a default, overridable per card individually.
    Section styling: Section background color picker with gradient toggle — two color pickers and angle control. Top, bottom, left, right padding controls for the entire section. Max content width control.
    Typography: All text elements have individual font size, color, font weight, and alignment controls.
    Responsive: Desktop shows 3 columns side by side. Mobile shows single column, cards stacked vertically, full width.
    Every single setting must be exposed and clearly labeled in the Shopify theme editor sidebar, organized into logical groups.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-how-it-works-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background: {% if block.settings.enable_gradient %}linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.background_color }}, {{ block.settings.gradient_color }}){% else %}{{ block.settings.background_color }}{% endif %};
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    padding-left: {{ block.settings.section_padding_left }}px;
    padding-right: {{ block.settings.section_padding_right }}px;
  }

  .ai-how-it-works-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_content_width }}px;
    margin: 0 auto;
  }

  .ai-how-it-works-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-how-it-works-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size }}px;
    color: {{ block.settings.eyebrow_color }};
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    margin-bottom: 12px;
    text-transform: uppercase;
    {% if block.settings.show_eyebrow == false %}display: none;{% endif %}
  }

  .ai-how-it-works-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    font-weight: {{ block.settings.heading_font_weight }};
    margin: 0;
  }

  .ai-how-it-works-cards-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    gap: {{ block.settings.card_gap_desktop }}px;
    justify-content: center;
    align-items: stretch;
  }

  .ai-how-it-works-card-{{ ai_gen_id }} {
    flex: 1;
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding-top: {{ block.settings.card_padding_top }}px;
    padding-bottom: {{ block.settings.card_padding_bottom }}px;
    padding-left: {{ block.settings.card_padding_left }}px;
    padding-right: {{ block.settings.card_padding_right }}px;
    {% if block.settings.card_min_height > 0 %}min-height: {{ block.settings.card_min_height }}px;{% endif %}
    {% if block.settings.enable_card_border %}border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};{% endif %}
    {% if block.settings.enable_card_shadow %}box-shadow: {{ block.settings.card_shadow_offset_x }}px {{ block.settings.card_shadow_offset_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};{% endif %}
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-how-it-works-badge-{{ ai_gen_id }} {
    width: {{ block.settings.badge_size }}px;
    height: {{ block.settings.badge_size }}px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.badge_size | times: 0.5 }}px;
    font-weight: 700;
    color: {{ block.settings.badge_text_color }};
    margin-bottom: 20px;
  }

  .ai-how-it-works-badge-1-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_1_bg_color }};
  }

  .ai-how-it-works-badge-2-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_2_bg_color }};
  }

  .ai-how-it-works-badge-3-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_3_bg_color }};
  }

  .ai-how-it-works-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: 20px;
    padding-top: {{ block.settings.image_padding_top }}px;
    padding-bottom: {{ block.settings.image_padding_bottom }}px;
    padding-left: {{ block.settings.image_padding_left }}px;
    padding-right: {{ block.settings.image_padding_right }}px;
  }

  .ai-how-it-works-image-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.image_aspect_ratio == '1:1' %}
      padding-bottom: 100%;
    {% elsif block.settings.image_aspect_ratio == '4:3' %}
      padding-bottom: 75%;
    {% elsif block.settings.image_aspect_ratio == '16:9' %}
      padding-bottom: 56.25%;
    {% endif %}
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    {% if block.settings.enable_image_border %}border: {{ block.settings.image_border_thickness }}px solid {{ block.settings.image_border_color }};{% endif %}
    {% if block.settings.enable_image_shadow %}box-shadow: {{ block.settings.image_shadow_offset_x }}px {{ block.settings.image_shadow_offset_y }}px {{ block.settings.image_shadow_blur }}px {{ block.settings.image_shadow_color }};{% endif %}
  }

  .ai-how-it-works-image-{{ ai_gen_id }} {
    {% if block.settings.image_aspect_ratio != 'free' %}
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    {% else %}
      width: {{ block.settings.global_image_width }}%;
      height: auto;
    {% endif %}
    object-fit: {{ block.settings.image_fit_mode }};
    object-position: {{ block.settings.image_object_position }};
    {% if block.settings.image_rendering == 'high' %}image-rendering: -webkit-optimize-contrast; image-rendering: crisp-edges;{% endif %}
  }

  .ai-how-it-works-image-placeholder-{{ ai_gen_id }} {
    {% if block.settings.image_aspect_ratio != 'free' %}
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
    {% else %}
      width: {{ block.settings.global_image_width }}%;
      height: auto;
    {% endif %}
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-how-it-works-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-how-it-works-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_font_size }}px;
    color: {{ block.settings.card_title_color }};
    font-weight: {{ block.settings.card_title_font_weight }};
    margin: 0 0 12px 0;
    text-align: center;
  }

  .ai-how-it-works-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_font_size }}px;
    color: {{ block.settings.card_description_color }};
    line-height: {{ block.settings.card_description_line_height }};
    margin: 0;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-how-it-works-cards-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.card_gap_mobile }}px;
    }

    .ai-how-it-works-card-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<how-it-works-{{ ai_gen_id }} class="ai-how-it-works-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-how-it-works-container-{{ ai_gen_id }}">
    <div class="ai-how-it-works-header-{{ ai_gen_id }}">
      {% if block.settings.eyebrow_text != blank %}
        <div class="ai-how-it-works-eyebrow-{{ ai_gen_id }}">
          {{ block.settings.eyebrow_text }}
        </div>
      {% endif %}
      {% if block.settings.heading_text != blank %}
        <h2 class="ai-how-it-works-heading-{{ ai_gen_id }}">
          {{ block.settings.heading_text }}
        </h2>
      {% endif %}
    </div>

    <div class="ai-how-it-works-cards-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign step_image_key = 'step_' | append: i | append: '_image'
          assign step_title_key = 'step_' | append: i | append: '_title'
          assign step_description_key = 'step_' | append: i | append: '_description'
          assign step_image_width_key = 'step_' | append: i | append: '_image_width'
          
          assign step_image = block.settings[step_image_key]
          assign step_title = block.settings[step_title_key]
          assign step_description = block.settings[step_description_key]
          assign step_image_width = block.settings[step_image_width_key]
        %}

        <div class="ai-how-it-works-card-{{ ai_gen_id }}">
          <div class="ai-how-it-works-badge-{{ ai_gen_id }} ai-how-it-works-badge-{{ i }}-{{ ai_gen_id }}">
            {{ i }}
          </div>

          <div class="ai-how-it-works-image-wrapper-{{ ai_gen_id }}">
            <div class="ai-how-it-works-image-container-{{ ai_gen_id }}">
              {% if step_image != blank %}
                <img
                  src="{{ step_image | image_url: width: 800 }}"
                  alt="{{ step_image.alt | escape }}"
                  loading="lazy"
                  width="{{ step_image.width }}"
                  height="{{ step_image.height }}"
                  class="ai-how-it-works-image-{{ ai_gen_id }}"
                  {% if step_image_width > 0 %}
                    style="width: {{ step_image_width }}%;"
                  {% endif %}
                >
              {% else %}
                <div class="ai-how-it-works-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          </div>

          {% if step_title != blank %}
            <h3 class="ai-how-it-works-card-title-{{ ai_gen_id }}">
              {{ step_title }}
            </h3>
          {% endif %}

          {% if step_description != blank %}
            <p class="ai-how-it-works-card-description-{{ ai_gen_id }}">
              {{ step_description }}
            </p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</how-it-works-{{ ai_gen_id }}>

<script>
  (function() {
    class HowItWorks{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('how-it-works-{{ ai_gen_id }}', HowItWorks{{ ai_gen_id }});
  })();
</script>

