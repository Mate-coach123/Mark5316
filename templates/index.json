      "blocks": {
        "item_dNrECL": {
          "type": "item",
          "settings": {
            "title": "Aké je to vdychovať aromatizovaný vzduch?",
            "content": "<p>Aromatizovaný vzduch Qlean poskytuje príjemnú, prirodzenú chuť, ktorá môže pomôcť pri zanechaní škodlivých návykov.</p><p>Je menej intenzívny ako para, ale osviežujúci – pripomína jemne lúhovaný bylinkový čaj alebo nesýtenú ochutenú vodu.</p>"
          }
        },
        "item_kDzycT": {
          "type": "item",
          "settings": {
            "title": "Ako funguje Qlean?",
            "content": "<p>Qlean ponúka vzduch s prirodzenou príchuťou, ktorý poskytuje príjemný a osviežujúci zážitok podporujúci vedomé zmeny životného štýlu.</p><p>Vytvorený zo 100 % prírodných ingrediencií predstavuje cenovo dostupnú alternatívu pre tých, ktorí si chcú vytvoriť nové návyky. Zachovanie známeho pohybu ruka–ústa môže navyše uľahčiť zavedenie nových rutín do každodenného života.</p>"
          }
        },
        "item_7p3Tek": {
          "type": "item",
          "settings": {
            "title": "Ako používať Qlean?",
            "content": "<p>Používanie Qleanu je jednoduché – stačia 3 kroky:</p><ol><li>Zmäkči svoj obľúbený aromatizovaný náplňový vložok.<br/></li><li>Vlož vložku do zariadenia Qlean.<br/></li><li>Užívaj si osviežujúci zážitok z prírodnej aromaterapie!</li></ol>"
          }
        },
        "item_iKgcpa": {
          "type": "item",
          "settings": {
            "title": "Je Qlean bezpečný?",
            "content": "<p><strong>Samozrejme!</strong><br/><br/>Qlean je zo 100 % vyrobený z prírodných surovín, vrátane čistých esenciálnych olejov, rastlinných extraktov a prírodných aróm.</p><p>Neobsahuje nikotín, produkty horenia ani umelé prísady, vďaka čomu predstavuje osviežujúcu, prirodzenú alternatívu na každý deň.</p>"
          }
        },
        "item_xpgdhc": {
          "type": "item",
          "settings": {
            "title": "Ako dlho vydrží aromatizovaná náplň?",
            "content": "<p>Každá aromatizovaná náplň vydrží 2–3 dni pravidelného používania, v závislosti od toho, ako často používaš Qlean.</p><p></p>"
          }
        },
        "item_iwnycK": {
          "type": "item",
          "settings": {
            "title": "Čo obsahuje balenie?",
            "content": "<p>Obsah balenia:</p><ul><li>1 ks – Qlean POD Difuzér<br/></li><li>2 balenia – Qlean aromatizované náplne<br/></li><li>1 ks – Čistiaca sada Qlean</li></ul>"
          }
        }
      },
