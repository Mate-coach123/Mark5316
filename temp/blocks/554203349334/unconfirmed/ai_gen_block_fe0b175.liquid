{% doc %}
  @prompt
    Create a fully customizable Shopify comparison table section with a heading on the left and a comparison table on the right, displayed side by side on desktop and stacked vertically on mobile.
    IMPORTANT: The brand column header (Ergorest) and the competitor column header must have rounded corners at the top — border-radius applied to the top-left and top-right corners of each header cell. The entire column highlight under the brand column must also have rounded corners at the bottom — so the brand column looks like a rounded pill or card shape from top to bottom. Border radius control must be available in settings to adjust the roundness.
    Left side: An editable main heading split into two lines — first line in dark color, second line in a custom accent color in purple italic. Font size, weight, color, and alignment controls for each line separately. Optional short subtitle below the heading. Heading vertical alignment control.
    Right side — comparison table: Two columns: Ergorest (brand, highlighted) and Hagyományos párna (competitor). Each column has an editable header label. Brand column header color picker. Competitor column header color picker. Brand column background color picker. Competitor column background color picker.
    Table rows: Up to 8 editable rows, each with a feature label and a checkmark or X for each column. Editable text per row. Toggle check or X per cell independently. Font size and color for feature labels. Toggle to show or hide each row.
    Checkmark and X icon settings: Icon style selector. Checkmark color picker. X icon color picker. Icon size control.
    Table styling: Table border radius control (applied to the whole table and the column highlight card). Row divider color and thickness. Cell padding controls. Table shadow toggle. Table border toggle with color and thickness.
    Section layout: Left and right column width ratio control. Section background color picker with gradient toggle. Top, bottom, left, right padding for the section. Max content width. Gap between left and right side.
    Mobile settings: Heading stacks above table on mobile, centered. Separate font size controls for mobile. Separate cell padding for mobile. Icon size override for mobile. Toggle for horizontal scroll or condensed layout on mobile.
    Every setting clearly labeled and organized in the Shopify theme editor sidebar.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-section-{{ ai_gen_id }} {
    display: block;
    background: {% if block.settings.enable_gradient %}linear-gradient(135deg, {{ block.settings.section_background }}, {{ block.settings.section_background_gradient }}){% else %}{{ block.settings.section_background }}{% endif %};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-comparison-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    gap: {{ block.settings.column_gap }}px;
    align-items: {% if block.settings.heading_vertical_align == 'top' %}flex-start{% elsif block.settings.heading_vertical_align == 'center' %}center{% else %}flex-end{% endif %};
  }

  .ai-comparison-left-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.left_column_width }}%;
  }

  .ai-comparison-right-{{ ai_gen_id }} {
    flex: 0 0 calc({{ 100 | minus: block.settings.left_column_width }}% - {{ block.settings.column_gap }}px);
  }

  .ai-comparison-heading-{{ ai_gen_id }} {
    margin: 0;
    text-align: {{ block.settings.heading_align }};
  }

  .ai-comparison-heading-line1-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.heading_line1_color }};
    font-size: {{ block.settings.heading_line1_size }}px;
    font-weight: {{ block.settings.heading_line1_weight }};
  }

  .ai-comparison-heading-line2-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.heading_line2_color }};
    font-size: {{ block.settings.heading_line2_size }}px;
    font-weight: {{ block.settings.heading_line2_weight }};
    font-style: italic;
  }

  .ai-comparison-subtitle-{{ ai_gen_id }} {
    margin-top: 12px;
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    text-align: {{ block.settings.heading_align }};
  }

  .ai-comparison-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    overflow: hidden;
    border-radius: {{ block.settings.table_border_radius }}px;
    {% if block.settings.enable_table_shadow %}
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    {% endif %}
    {% if block.settings.enable_table_border %}
      border: {{ block.settings.table_border_thickness }}px solid {{ block.settings.table_border_color }};
    {% endif %}
  }

  .ai-comparison-table-{{ ai_gen_id }} thead th {
    padding: {{ block.settings.header_padding_vertical }}px {{ block.settings.header_padding_horizontal }}px;
    font-weight: 700;
    font-size: {{ block.settings.header_font_size }}px;
    text-align: center;
  }

  .ai-comparison-table-{{ ai_gen_id }} thead th:first-child {
    background-color: {{ block.settings.brand_header_color }};
    color: {{ block.settings.brand_header_text_color }};
    border-top-left-radius: {{ block.settings.table_border_radius }}px;
    border-top-right-radius: 0;
  }

  .ai-comparison-table-{{ ai_gen_id }} thead th:last-child {
    background-color: {{ block.settings.competitor_header_color }};
    color: {{ block.settings.competitor_header_text_color }};
    border-top-left-radius: 0;
    border-top-right-radius: {{ block.settings.table_border_radius }}px;
  }

  .ai-comparison-table-{{ ai_gen_id }} tbody tr {
    {% if block.settings.row_divider_thickness > 0 %}
      border-bottom: {{ block.settings.row_divider_thickness }}px solid {{ block.settings.row_divider_color }};
    {% endif %}
  }

  .ai-comparison-table-{{ ai_gen_id }} tbody tr:last-child {
    border-bottom: none;
  }

  .ai-comparison-table-{{ ai_gen_id }} tbody td {
    padding: {{ block.settings.cell_padding_vertical }}px {{ block.settings.cell_padding_horizontal }}px;
    text-align: center;
  }

  .ai-comparison-table-{{ ai_gen_id }} tbody td:first-child {
    background-color: {{ block.settings.brand_column_bg }};
    color: {{ block.settings.brand_column_text }};
  }

  .ai-comparison-table-{{ ai_gen_id }} tbody td:last-child {
    background-color: {{ block.settings.competitor_column_bg }};
    color: {{ block.settings.competitor_column_text }};
  }

  .ai-comparison-table-{{ ai_gen_id }} tbody tr:last-child td:first-child {
    border-bottom-left-radius: {{ block.settings.table_border_radius }}px;
  }

  .ai-comparison-table-{{ ai_gen_id }} tbody tr:last-child td:last-child {
    border-bottom-right-radius: {{ block.settings.table_border_radius }}px;
  }

  .ai-comparison-feature-{{ ai_gen_id }} {
    font-size: {{ block.settings.feature_font_size }}px;
    color: {{ block.settings.feature_text_color }};
    font-weight: 500;
    text-align: left;
    padding-left: {{ block.settings.cell_padding_horizontal }}px;
  }

  .ai-comparison-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: inline-block;
  }

  .ai-comparison-check-{{ ai_gen_id }} {
    color: {{ block.settings.check_color }};
  }

  .ai-comparison-x-{{ ai_gen_id }} {
    color: {{ block.settings.x_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 32px;
    }

    .ai-comparison-left-{{ ai_gen_id }},
    .ai-comparison-right-{{ ai_gen_id }} {
      flex: 0 0 100%;
      width: 100%;
    }

    .ai-comparison-heading-{{ ai_gen_id }} {
      text-align: center;
    }

    .ai-comparison-subtitle-{{ ai_gen_id }} {
      text-align: center;
    }

    .ai-comparison-heading-line1-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_line1_size_mobile }}px;
    }

    .ai-comparison-heading-line2-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_line2_size_mobile }}px;
    }

    .ai-comparison-table-{{ ai_gen_id }} tbody td {
      padding: {{ block.settings.cell_padding_vertical_mobile }}px {{ block.settings.cell_padding_horizontal_mobile }}px;
    }

    .ai-comparison-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    {% if block.settings.mobile_scroll %}
      .ai-comparison-table-wrapper-{{ ai_gen_id }} {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
    {% endif %}
  }
{% endstyle %}

<div class="ai-comparison-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-comparison-container-{{ ai_gen_id }}">
    <div class="ai-comparison-left-{{ ai_gen_id }}">
      {% if block.settings.heading_line1 != blank or block.settings.heading_line2 != blank %}
        <h2 class="ai-comparison-heading-{{ ai_gen_id }}">
          {% if block.settings.heading_line1 != blank %}
            <span class="ai-comparison-heading-line1-{{ ai_gen_id }}">{{ block.settings.heading_line1 }}</span>
          {% endif %}
          {% if block.settings.heading_line2 != blank %}
            <span class="ai-comparison-heading-line2-{{ ai_gen_id }}">{{ block.settings.heading_line2 }}</span>
          {% endif %}
        </h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-comparison-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-comparison-right-{{ ai_gen_id }}">
      <div class="ai-comparison-table-wrapper-{{ ai_gen_id }}">
        <table class="ai-comparison-table-{{ ai_gen_id }}">
          <thead>
            <tr>
              <th>{{ block.settings.brand_header_label }}</th>
              <th>{{ block.settings.competitor_header_label }}</th>
            </tr>
          </thead>
          <tbody>
            {% for i in (1..8) %}
              {% assign row_enabled_key = 'row_' | append: i | append: '_enabled' %}
              {% assign row_label_key = 'row_' | append: i | append: '_label' %}
              {% assign row_brand_key = 'row_' | append: i | append: '_brand' %}
              {% assign row_competitor_key = 'row_' | append: i | append: '_competitor' %}

              {% if block.settings[row_enabled_key] %}
                <tr>
                  <td>
                    <div class="ai-comparison-feature-{{ ai_gen_id }}">{{ block.settings[row_label_key] }}</div>
                  </td>
                  <td>
                    {% if block.settings[row_brand_key] %}
                      <span class="ai-comparison-icon-{{ ai_gen_id }} ai-comparison-check-{{ ai_gen_id }}">
                        {% if block.settings.icon_style == 'filled' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                          </svg>
                        {% elsif block.settings.icon_style == 'outline' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        {% else %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        {% endif %}
                      </span>
                    {% else %}
                      <span class="ai-comparison-icon-{{ ai_gen_id }} ai-comparison-x-{{ ai_gen_id }}">
                        {% if block.settings.icon_style == 'filled' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/>
                          </svg>
                        {% elsif block.settings.icon_style == 'outline' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                          </svg>
                        {% else %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                          </svg>
                        {% endif %}
                      </span>
                    {% endif %}
                  </td>
                  <td>
                    {% if block.settings[row_competitor_key] %}
                      <span class="ai-comparison-icon-{{ ai_gen_id }} ai-comparison-check-{{ ai_gen_id }}">
                        {% if block.settings.icon_style == 'filled' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                          </svg>
                        {% elsif block.settings.icon_style == 'outline' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        {% else %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="20 6 9 17 4 12"></polyline>
                          </svg>
                        {% endif %}
                      </span>
                    {% else %}
                      <span class="ai-comparison-icon-{{ ai_gen_id }} ai-comparison-x-{{ ai_gen_id }}">
                        {% if block.settings.icon_style == 'filled' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 2C6.47 2 2 6.47 2 12s4.47 10 10 10 10-4.47 10-10S17.53 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/>
                          </svg>
                        {% elsif block.settings.icon_style == 'outline' %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                          </svg>
                        {% else %}
                          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18"></line>
                            <line x1="6" y1="6" x2="18" y2="18"></line>
                          </svg>
                        {% endif %}
                      </span>
                    {% endif %}
                  </td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Comparison table",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "Why Choose"
    },
    {
      "type": "color",
      "id": "heading_line1_color",
      "label": "Line 1 color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "heading_line1_size",
      "label": "Line 1 size (desktop)",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_line1_size_mobile",
      "label": "Line 1 size (mobile)",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_line1_weight",
      "label": "Line 1 weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2",
      "default": "Ergorest?"
    },
    {
      "type": "color",
      "id": "heading_line2_color",
      "label": "Line 2 color",
      "default": "#8d5eb2"
    },
    {
      "type": "range",
      "id": "heading_line2_size",
      "label": "Line 2 size (desktop)",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_line2_size_mobile",
      "label": "Line 2 size (mobile)",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_line2_weight",
      "label": "Line 2 weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_vertical_align",
      "label": "Heading vertical alignment",
      "options": [
        { "value": "top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "bottom", "label": "Bottom" }
      ],
      "default": "center"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Table headers"
    },
    {
      "type": "text",
      "id": "brand_header_label",
      "label": "Brand column header",
      "default": "Ergorest"
    },
    {
      "type": "color",
      "id": "brand_header_color",
      "label": "Brand header background",
      "default": "#8d5eb2"
    },
    {
      "type": "color",
      "id": "brand_header_text_color",
      "label": "Brand header text",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "competitor_header_label",
      "label": "Competitor column header",
      "default": "Hagyományos párna"
    },
    {
      "type": "color",
      "id": "competitor_header_color",
      "label": "Competitor header background",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "competitor_header_text_color",
      "label": "Competitor header text",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "header_font_size",
      "label": "Header font size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "header_padding_vertical",
      "label": "Header padding vertical",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "header_padding_horizontal",
      "label": "Header padding horizontal",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Table columns"
    },
    {
      "type": "color",
      "id": "brand_column_bg",
      "label": "Brand column background",
      "default": "#f5eeff"
    },
    {
      "type": "color",
      "id": "brand_column_text",
      "label": "Brand column text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "competitor_column_bg",
      "label": "Competitor column background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "competitor_column_text",
      "label": "Competitor column text",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Table styling"
    },
    {
      "type": "range",
      "id": "table_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "enable_table_shadow",
      "label": "Enable shadow",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_table_border",
      "label": "Enable border",
      "default": false
    },
    {
      "type": "color",
      "id": "table_border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "table_border_thickness",
      "label": "Border thickness",
      "min": 1,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "row_divider_color",
      "label": "Row divider color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "row_divider_thickness",
      "label": "Row divider thickness",
      "min": 0,
      "max": 5,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "cell_padding_vertical",
      "label": "Cell padding vertical (desktop)",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "cell_padding_horizontal",
      "label": "Cell padding horizontal (desktop)",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "cell_padding_vertical_mobile",
      "label": "Cell padding vertical (mobile)",
      "min": 6,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "cell_padding_horizontal_mobile",
      "label": "Cell padding horizontal (mobile)",
      "min": 6,
      "max": 30,
      "step": 2,
      "unit": "px",
