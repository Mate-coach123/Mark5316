{% doc %}
  @prompt
    Create a Shopify rich text section with a fully customizable button as the main focus. The section must have the following settings:
    Layout & Spacing: Individual top padding and bottom padding controls. Individual left and right padding controls.
    Button settings: Editable button label text. Link field to connect the button to any URL or product. Button background color picker. Button text color picker. Button border radius control (from square to fully rounded pill shape). Button box shadow toggle with shadow color and intensity controls. Button width control (auto/fit content or full width).
    Button alignment — desktop and mobile separately: A dropdown to set button alignment on desktop (left, center, right). A separate dropdown to set button alignment on mobile (left, center, right). These two settings must work independently so desktop can be left-aligned while mobile is centered, with no overlap or conflict between the two.
    Rich text content: Optional heading field above the button. Optional subtext/paragraph field above or below the button. Text color control. Text alignment control (separate for desktop and mobile).
    Background: Section background color picker.
    The desktop and mobile alignment settings must be fully separate and must not interfere with each other — if desktop is set to left, mobile must still show centered independently.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-text-button-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    padding-left: {{ block.settings.padding_left }}px;
    padding-right: {{ block.settings.padding_right }}px;
  }

  .ai-rich-text-button__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-rich-text-button__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .ai-rich-text-button__text-wrapper-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: {{ block.settings.text_align_desktop }};
  }

  .ai-rich-text-button__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    font-size: 32px;
    font-weight: 600;
  }

  .ai-rich-text-button__subtext-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
  }

  .ai-rich-text-button__button-wrapper-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.button_align_desktop }};
  }

  .ai-rich-text-button__button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    {% if block.settings.button_width == 'full' %}
      width: 100%;
    {% else %}
      width: auto;
    {% endif %}
    {% if block.settings.button_shadow_enabled %}
      box-shadow: 0 {{ block.settings.button_shadow_intensity }}px {{ block.settings.button_shadow_intensity | times: 2 }}px {{ block.settings.button_shadow_color }};
    {% endif %}
  }

  .ai-rich-text-button__button-{{ ai_gen_id }}:hover {
    transform: translateY(-2px);
    {% if block.settings.button_shadow_enabled %}
      box-shadow: 0 {{ block.settings.button_shadow_intensity | times: 1.5 }}px {{ block.settings.button_shadow_intensity | times: 3 }}px {{ block.settings.button_shadow_color }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-rich-text-button__text-wrapper-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_align_mobile }};
    }

    .ai-rich-text-button__button-wrapper-{{ ai_gen_id }} {
      justify-content: {{ block.settings.button_align_mobile }};
    }

    .ai-rich-text-button__heading-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-rich-text-button__subtext-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-rich-text-button-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-rich-text-button__container-{{ ai_gen_id }}">
    <div class="ai-rich-text-button__content-{{ ai_gen_id }}">
      <div class="ai-rich-text-button__text-wrapper-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-rich-text-button__heading-{{ ai_gen_id }}">
            {{ block.settings.heading }}
          </h2>
        {% endif %}

        {% if block.settings.subtext != blank %}
          <div class="ai-rich-text-button__subtext-{{ ai_gen_id }}">
            {{ block.settings.subtext }}
          </div>
        {% endif %}
      </div>

      <div class="ai-rich-text-button__button-wrapper-{{ ai_gen_id }}">
        <a
          href="{{ block.settings.button_link }}"
          class="ai-rich-text-button__button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_label }}
        </a>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Rich text with button",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Left padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Right padding",
      "default": 20
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Text content"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "default": "<p>Discover our collection</p>"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Explore our latest products and find exactly what you need.</p>"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "text_align_desktop",
      "label": "Text alignment (desktop)",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align_mobile",
      "label": "Text alignment (mobile)",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 4
    },
    {
      "type": "select",
      "id": "button_width",
      "label": "Width",
      "options": [
        {
          "value": "auto",
          "label": "Auto / Fit content"
        },
        {
          "value": "full",
          "label": "Full width"
        }
      ],
      "default": "auto"
    },
    {
      "type": "select",
      "id": "button_align_desktop",
      "label": "Alignment (desktop)",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "button_align_mobile",
      "label": "Alignment (mobile)",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Button shadow"
    },
    {
      "type": "checkbox",
      "id": "button_shadow_enabled",
      "label": "Enable shadow",
      "default": true
    },
    {
      "type": "color",
      "id": "button_shadow_color",
      "label": "Shadow color",
      "default": "rgba(0, 0, 0, 0.15)"
    },
    {
      "type": "range",
      "id": "button_shadow_intensity",
      "min": 2,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Shadow intensity",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Rich text with button"
    }
  ]
}
{% endschema %}
