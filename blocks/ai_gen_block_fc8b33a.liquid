{% doc %}
  @prompt
    Create a fully customizable Shopify "How it works" transformation section with 3 step cards displayed side by side on desktop and stacked vertically on mobile.
    Section header: An optional small eyebrow label above the main title (e.g. "SOSEM VOLT ILYEN EGYSZERŰ") with font size, color, letter spacing, and visibility toggle. A large bold main heading below it with font size, color, and weight controls. Both centered.
    Step cards layout: 3 cards displayed in a horizontal row on desktop (equal width, side by side). On mobile they stack vertically, full width, one below the other. Gap between cards adjustable. Card alignment centered.
    Each card contains:
    A step number badge at the top center of the card — a circle with a number inside (1, 2, 3). Badge background color picker per step. Badge text color picker. Badge size control. Badge border radius (fully round by default). Option to give each badge a different color independently.
    An emoji or icon field below the badge — editable text field where any emoji can be typed. Font size control for the emoji. Centered.
    A bold card title below the emoji with font size, color, and weight controls.
    A short description text below the title with font size, color, and line height controls.
    Card styling: Card background color picker. Card border radius control. Card border toggle with color and thickness controls. Card box shadow toggle with shadow color, blur radius, and offset controls. Individual top, bottom, left, right padding controls inside each card. Option to set card minimum height.
    Section styling: Section background color picker with gradient toggle (two color pickers and angle control). Top and bottom padding controls for the entire section. Left and right padding controls. Max content width control.
    Typography: All text elements have individual font size, color, font weight, and text alignment controls. Global font size scale option.
    Responsive behavior: On desktop: 3 columns side by side. On mobile: single column, cards stacked vertically, full width. Gap between cards adjustable separately for desktop and mobile.
    Make every single setting exposed in the Shopify theme editor sidebar, clearly labeled and organized into logical groups.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-how-it-works-{{ ai_gen_id }} {
    display: block;
    background-color: {{ block.settings.section_bg_color }};
    {% if block.settings.enable_gradient %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.section_bg_color }} 0%, {{ block.settings.gradient_color }} 100%);
    {% endif %}
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    padding-left: {{ block.settings.section_padding_left }}px;
    padding-right: {{ block.settings.section_padding_right }}px;
  }

  .ai-how-it-works-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_content_width }}px;
    margin: 0 auto;
  }

  .ai-how-it-works-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_bottom_margin }}px;
  }

  .ai-how-it-works-eyebrow-{{ ai_gen_id }} {
    font-size: {{ block.settings.eyebrow_font_size }}px;
    color: {{ block.settings.eyebrow_color }};
    letter-spacing: {{ block.settings.eyebrow_letter_spacing }}px;
    margin-bottom: {{ block.settings.eyebrow_bottom_margin }}px;
    font-weight: {{ block.settings.eyebrow_font_weight }};
    text-transform: uppercase;
  }

  .ai-how-it-works-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    font-weight: {{ block.settings.heading_font_weight }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-how-it-works-cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.cards_gap_desktop }}px;
    align-items: stretch;
  }

  .ai-how-it-works-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding-top: {{ block.settings.card_padding_top }}px;
    padding-bottom: {{ block.settings.card_padding_bottom }}px;
    padding-left: {{ block.settings.card_padding_left }}px;
    padding-right: {{ block.settings.card_padding_right }}px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    {% if block.settings.card_min_height > 0 %}
      min-height: {{ block.settings.card_min_height }}px;
    {% endif %}
    {% if block.settings.enable_card_border %}
      border: {{ block.settings.card_border_thickness }}px solid {{ block.settings.card_border_color }};
    {% endif %}
    {% if block.settings.enable_card_shadow %}
      box-shadow: {{ block.settings.shadow_offset_x }}px {{ block.settings.shadow_offset_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    {% endif %}
  }

  .ai-how-it-works-badge-{{ ai_gen_id }} {
    width: {{ block.settings.badge_size }}px;
    height: {{ block.settings.badge_size }}px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.badge_number_size }}px;
    font-weight: 700;
    margin-bottom: {{ block.settings.badge_bottom_margin }}px;
    flex-shrink: 0;
  }

  .ai-how-it-works-badge-1-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_1_bg_color }};
    color: {{ block.settings.badge_1_text_color }};
  }

  .ai-how-it-works-badge-2-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_2_bg_color }};
    color: {{ block.settings.badge_2_text_color }};
  }

  .ai-how-it-works-badge-3-{{ ai_gen_id }} {
    background-color: {{ block.settings.badge_3_bg_color }};
    color: {{ block.settings.badge_3_text_color }};
  }

  .ai-how-it-works-emoji-{{ ai_gen_id }} {
    font-size: {{ block.settings.emoji_font_size }}px;
    margin-bottom: {{ block.settings.emoji_bottom_margin }}px;
    line-height: 1;
  }

  .ai-how-it-works-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_font_size }}px;
    color: {{ block.settings.card_title_color }};
    font-weight: {{ block.settings.card_title_font_weight }};
    margin: 0 0 {{ block.settings.card_title_bottom_margin }}px 0;
    text-align: {{ block.settings.card_title_alignment }};
  }

  .ai-how-it-works-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_font_size }}px;
    color: {{ block.settings.card_description_color }};
    line-height: {{ block.settings.card_description_line_height }};
    margin: 0;
    text-align: {{ block.settings.card_description_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-how-it-works-cards-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.cards_gap_mobile }}px;
    }

    .ai-how-it-works-eyebrow-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.eyebrow_font_size }}px * {{ block.settings.mobile_font_scale }});
    }

    .ai-how-it-works-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_font_size }}px * {{ block.settings.mobile_font_scale }});
    }

    .ai-how-it-works-card-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_title_font_size }}px * {{ block.settings.mobile_font_scale }});
    }

    .ai-how-it-works-card-description-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.card_description_font_size }}px * {{ block.settings.mobile_font_scale }});
    }
  }
{% endstyle %}

<how-it-works-{{ ai_gen_id }} class="ai-how-it-works-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-how-it-works-container-{{ ai_gen_id }}">
    <div class="ai-how-it-works-header-{{ ai_gen_id }}">
      {% if block.settings.show_eyebrow and block.settings.eyebrow_text != blank %}
        <div class="ai-how-it-works-eyebrow-{{ ai_gen_id }}">
          {{ block.settings.eyebrow_text }}
        </div>
      {% endif %}
      {% if block.settings.heading_text != blank %}
        <h2 class="ai-how-it-works-heading-{{ ai_gen_id }}">
          {{ block.settings.heading_text }}
        </h2>
      {% endif %}
    </div>

    <div class="ai-how-it-works-cards-{{ ai_gen_id }}">
      <div class="ai-how-it-works-card-{{ ai_gen_id }}">
        <div class="ai-how-it-works-badge-{{ ai_gen_id }} ai-how-it-works-badge-1-{{ ai_gen_id }}">
          1
        </div>
        {% if block.settings.step_1_emoji != blank %}
          <div class="ai-how-it-works-emoji-{{ ai_gen_id }}">
            {{ block.settings.step_1_emoji }}
          </div>
        {% endif %}
        {% if block.settings.step_1_title != blank %}
          <h3 class="ai-how-it-works-card-title-{{ ai_gen_id }}">
            {{ block.settings.step_1_title }}
          </h3>
        {% endif %}
        {% if block.settings.step_1_description != blank %}
          <p class="ai-how-it-works-card-description-{{ ai_gen_id }}">
            {{ block.settings.step_1_description }}
          </p>
        {% endif %}
      </div>

      <div class="ai-how-it-works-card-{{ ai_gen_id }}">
        <div class="ai-how-it-works-badge-{{ ai_gen_id }} ai-how-it-works-badge-2-{{ ai_gen_id }}">
          2
        </div>
        {% if block.settings.step_2_emoji != blank %}
          <div class="ai-how-it-works-emoji-{{ ai_gen_id }}">
            {{ block.settings.step_2_emoji }}
          </div>
        {% endif %}
        {% if block.settings.step_2_title != blank %}
          <h3 class="ai-how-it-works-card-title-{{ ai_gen_id }}">
            {{ block.settings.step_2_title }}
          </h3>
        {% endif %}
        {% if block.settings.step_2_description != blank %}
          <p class="ai-how-it-works-card-description-{{ ai_gen_id }}">
            {{ block.settings.step_2_description }}
          </p>
        {% endif %}
      </div>

      <div class="ai-how-it-works-card-{{ ai_gen_id }}">
        <div class="ai-how-it-works-badge-{{ ai_gen_id }} ai-how-it-works-badge-3-{{ ai_gen_id }}">
          3
        </div>
        {% if block.settings.step_3_emoji != blank %}
          <div class="ai-how-it-works-emoji-{{ ai_gen_id }}">
            {{ block.settings.step_3_emoji }}
          </div>
        {% endif %}
        {% if block.settings.step_3_title != blank %}
          <h3 class="ai-how-it-works-card-title-{{ ai_gen_id }}">
            {{ block.settings.step_3_title }}
          </h3>
        {% endif %}
        {% if block.settings.step_3_description != blank %}
          <p class="ai-how-it-works-card-description-{{ ai_gen_id }}">
            {{ block.settings.step_3_description }}
          </p>
        {% endif %}
      </div>
    </div>
  </div>
</how-it-works-{{ ai_gen_id }}>

<script>
  (function() {
    class HowItWorks{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('how-it-works-{{ ai_gen_id }}', HowItWorks{{ ai_gen_id }});
  })();
</script>

