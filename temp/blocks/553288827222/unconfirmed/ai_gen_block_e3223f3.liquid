{% doc %}
  @prompt
    Create a “Frequently Asked Questions (FAQ)” accordion section that looks and functions exactly like the example in the reference image.
    
    🟩 Design requirements:
    
    Each question should appear inside a rounded accordion block with a gradient background (adjustable from the editor).
    
    Add plus (+) and minus (–) icons on the right side of each question to open and close the answer — these should change automatically when expanded or collapsed.
    
    Allow customization of the icon color, size, and position.
    
    The entire section should have rounded corners and inner padding that can be customized for desktop and mobile separately.
    
    Each block (question/answer) should have separate color controls for:
    
    Question text color
    
    Answer text color
    
    Background gradient (two-color adjustable gradient)
    
    Border and shadow options
    
    🟩 Functionality:
    
    Allow adding, deleting, and reordering questions and answers directly in the editor.
    
    Each FAQ item should have editable fields:
    
    Question text
    
    Answer text (supports rich text, bold, italics, and links)
    
    Allow expanding multiple items at once or just one at a time (toggle option).
    
    Smooth open/close animation for better user experience.
    
    Support gradient animation or static color options.
    
    Fully responsive design — adjusts perfectly on all screen sizes.
    
    🟩 Style controls:
    
    Adjustable font size, font family, weight, and letter spacing for both questions and answers.
    
    Adjustable padding and margin between FAQ items.
    
    Option to change icon alignment (left or right).
    
    Option to adjust corner radius and shadow intensity.
    
    Allow custom heading above the FAQ section (e.g., “Frequently Asked Questions”), with editable text, color, font, and spacing.
    
    💡 The final section should look and behave like the reference image — modern, soft gradient background, clear typography, and minimalist icons on the right.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-accordion-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding_desktop }}px;
    background: linear-gradient(
      {{ block.settings.section_gradient_angle }}deg,
      {{ block.settings.section_gradient_color_1 }},
      {{ block.settings.section_gradient_color_2 }}
    );
    border-radius: {{ block.settings.section_border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-accordion-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px;
    }
  }

  .ai-faq-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
  }

  .ai-faq-items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.items_spacing }}px;
  }

  .ai-faq-item-{{ ai_gen_id }} {
    background: linear-gradient(
      {{ block.settings.item_gradient_angle }}deg,
      {{ block.settings.item_gradient_color_1 }},
      {{ block.settings.item_gradient_color_2 }}
    );
    border-radius: {{ block.settings.item_border_radius }}px;
    overflow: hidden;
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
    box-shadow: {{ block.settings.item_shadow_horizontal }}px {{ block.settings.item_shadow_vertical }}px {{ block.settings.item_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.item_shadow_opacity | divided_by: 100.0 }});
    transition: all 0.3s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}:hover {
    box-shadow: {{ block.settings.item_shadow_horizontal }}px {{ block.settings.item_shadow_vertical }}px {{ block.settings.item_shadow_blur | times: 1.5 }}px rgba(0, 0, 0, {{ block.settings.item_shadow_opacity | divided_by: 100.0 | times: 1.2 }});
  }

  .ai-faq-question-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: {{ block.settings.question_padding }}px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: {{ block.settings.question_font.family }}, {{ block.settings.question_font.fallback_families }};
    font-weight: {{ block.settings.question_font.weight }};
    font-size: {{ block.settings.question_font_size }}px;
    color: {{ block.settings.question_color }};
    letter-spacing: {{ block.settings.question_letter_spacing }}px;
    transition: color 0.3s ease;
  }

  .ai-faq-question-{{ ai_gen_id }}:hover {
    color: {{ block.settings.question_hover_color }};
  }

  .ai-faq-question-text-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-faq-icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    {% if block.settings.icon_position == 'left' %}
      order: -1;
    {% else %}
      order: 1;
    {% endif %}
  }

  .ai-faq-icon-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    color: {{ block.settings.icon_color }};
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .ai-faq-icon-plus-{{ ai_gen_id }} {
    position: absolute;
    opacity: 1;
  }

  .ai-faq-icon-minus-{{ ai_gen_id }} {
    position: absolute;
    opacity: 0;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-plus-{{ ai_gen_id }} {
    opacity: 0;
    transform: rotate(90deg);
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-icon-minus-{{ ai_gen_id }} {
    opacity: 1;
    transform: rotate(0deg);
  }

  .ai-faq-answer-wrapper-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
  }

  .ai-faq-item-{{ ai_gen_id }}.active .ai-faq-answer-wrapper-{{ ai_gen_id }} {
    max-height: 1000px;
  }

  .ai-faq-answer-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.question_padding }}px {{ block.settings.answer_padding }}px;
    font-family: {{ block.settings.answer_font.family }}, {{ block.settings.answer_font.fallback_families }};
    font-weight: {{ block.settings.answer_font.weight }};
    font-size: {{ block.settings.answer_font_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
    letter-spacing: {{ block.settings.answer_letter_spacing }}px;
  }

  .ai-faq-answer-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-faq-answer-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-faq-answer-{{ ai_gen_id }} a {
    color: {{ block.settings.answer_link_color }};
    text-decoration: underline;
  }

  .ai-faq-answer-{{ ai_gen_id }} strong {
    font-weight: 700;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size | times: 0.8 }}px;
    }

    .ai-faq-question-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_font_size | times: 0.9 }}px;
      padding: {{ block.settings.question_padding | times: 0.8 }}px;
    }

    .ai-faq-answer-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_font_size | times: 0.9 }}px;
      padding: 0 {{ block.settings.question_padding | times: 0.8 }}px {{ block.settings.answer_padding | times: 0.8 }}px;
    }

    .ai-faq-icon-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }}
  class="ai-faq-accordion-{{ ai_gen_id }}"
  data-allow-multiple="{{ block.settings.allow_multiple_open }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.section_heading != blank %}
    <h2 class="ai-faq-heading-{{ ai_gen_id }}">{{ block.settings.section_heading }}</h2>
  {% endif %}

  <div class="ai-faq-items-{{ ai_gen_id }}">
    {% for i in (1..8) %}
      {% assign question_key = 'question_' | append: i %}
      {% assign answer_key = 'answer_' | append: i %}
      {% assign question = block.settings[question_key] %}
      {% assign answer = block.settings[answer_key] %}

      {% if question != blank %}
        <div class="ai-faq-item-{{ ai_gen_id }}" data-faq-item>
          <button
            class="ai-faq-question-{{ ai_gen_id }}"
            aria-expanded="false"
            aria-controls="ai-faq-answer-{{ ai_gen_id }}-{{ i }}"
          >
            <span class="ai-faq-question-text-{{ ai_gen_id }}">{{ question }}</span>
            <span class="ai-faq-icon-wrapper-{{ ai_gen_id }}" style="position: relative;">
              <svg
                class="ai-faq-icon-{{ ai_gen_id }} ai-faq-icon-plus-{{ ai_gen_id }}"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              <svg
                class="ai-faq-icon-{{ ai_gen_id }} ai-faq-icon-minus-{{ ai_gen_id }}"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </span>
          </button>
          <div
            class="ai-faq-answer-wrapper-{{ ai_gen_id }}"
            id="ai-faq-answer-{{ ai_gen_id }}-{{ i }}"
          >
            <div class="ai-faq-answer-{{ ai_gen_id }}">
              {{ answer }}
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.allowMultiple = this.dataset.allowMultiple === 'true';
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('.ai-faq-question-{{ ai_gen_id }}');
          button.addEventListener('click', () => this.toggleItem(item));
        });
      }

      toggleItem(item) {
        const isActive = item.classList.contains('active');
        const button = item.querySelector('.ai-faq-question-{{ ai_gen_id }}');

        if (!this.allowMultiple) {
          this.items.forEach((otherItem) => {
            if (otherItem !== item) {
              otherItem.classList.remove('active');
              const otherButton = otherItem.querySelector('.ai-faq-question-{{ ai_gen_id }}');
              otherButton.setAttribute('aria-expanded', 'false');
            }
          });
        }

        if (isActive) {
          item.classList.remove('active');
          button.setAttribute('aria-expanded', 'false');
        } else {
          item.classList.add('active');
          button.setAttribute('aria-expanded', 'true');
        }
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

