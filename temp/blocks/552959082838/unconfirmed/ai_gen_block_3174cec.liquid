{% doc %}
  @prompt
    Create a Shopify statistics/results section that displays large numbered stats with labels, similar to a "Real Sleep Results" style layout. The section must be fully customizable with every possible setting.
    Layout: Display 3 to 5 stat items stacked vertically, each separated by a thin horizontal divider line. Each stat item contains a large number or percentage (e.g. "92%"), a bold label below it (e.g. "Saw improved sleep quality"), and an optional short description below the label.
    Stat number styling: Large font size control (default around 64–80px). Option to apply a gradient to the number text with two color pickers for gradient start and end color and a gradient direction control. Option for solid color instead of gradient with a color picker. Font weight control. Optional text shadow on the number with shadow color, blur radius, and offset controls.
    Label styling: Separate font size control. Font color picker. Font weight control. Optional letter spacing control.
    Description text: Optional smaller text below each label. Font size, color, and font style (normal or italic) controls.
    Divider lines: Toggle to show or hide dividers between stat items. Divider color picker. Divider thickness control in pixels. Divider width as percentage of section width. Divider alignment (left, center, full width).
    Section title: Editable main heading at the top. Option to split the heading into two parts — first part in solid color, second part in italic style with a different color or gradient (e.g. "Real Sleep" in dark + "Results" in purple italic). Font size, color, and weight controls for each part separately.
    Footer note: Optional small italic disclaimer text at the bottom of the section with an info icon before it. Font size and color controls.
    Background: Section background color picker with option to switch to a two-color gradient with gradient angle control. Default should be a very light lavender or off-white.
    Spacing: Individual top padding, bottom padding, left padding, and right padding controls for the entire section. Individual top and bottom padding controls for each stat item. Control for the gap between the number and the label.
    Alignment: Text alignment control for all content (left, center, right) separately for desktop and mobile.
    Number of stats: Setting to choose how many stat blocks to display (minimum 2, maximum 6) with each stat having its own number field, label field, description field, and individual color override option.
    Make the section clean, minimal, and premium — consistent with a wellness and sleep brand aesthetic.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stats-section-{{ ai_gen_id }} {
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    padding-left: {{ block.settings.section_padding_left }}px;
    padding-right: {{ block.settings.section_padding_right }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    {% if block.settings.background_type == 'solid' %}
      background-color: {{ block.settings.background_color }};
    {% else %}
      background: linear-gradient({{ block.settings.gradient_angle }}deg, {{ block.settings.gradient_color_1 }}, {{ block.settings.gradient_color_2 }});
    {% endif %}
  }

  .ai-stats-section__inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-stats-section__title-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.title_bottom_margin }}px;
    text-align: {{ block.settings.text_align_desktop }};
  }

  .ai-stats-section__title-part1-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_part1_font_size }}px;
    color: {{ block.settings.title_part1_color }};
    font-weight: {{ block.settings.title_part1_font_weight }};
    display: inline;
  }

  .ai-stats-section__title-part2-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_part2_font_size }}px;
    {% if block.settings.title_part2_style == 'gradient' %}
      background: linear-gradient({{ block.settings.title_part2_gradient_angle }}deg, {{ block.settings.title_part2_gradient_color_1 }}, {{ block.settings.title_part2_gradient_color_2 }});
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    {% else %}
      color: {{ block.settings.title_part2_color }};
    {% endif %}
    font-weight: {{ block.settings.title_part2_font_weight }};
    font-style: {{ block.settings.title_part2_font_style }};
    display: inline;
  }

  .ai-stats-section__items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-stats-section__item-{{ ai_gen_id }} {
    padding-top: {{ block.settings.stat_item_padding_top }}px;
    padding-bottom: {{ block.settings.stat_item_padding_bottom }}px;
    text-align: {{ block.settings.text_align_desktop }};
  }

  {% if block.settings.show_dividers %}
    .ai-stats-section__item-{{ ai_gen_id }}:not(:last-child) {
      border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
    }

    .ai-stats-section__divider-{{ ai_gen_id }} {
      width: {{ block.settings.divider_width }}%;
      height: {{ block.settings.divider_thickness }}px;
      background-color: {{ block.settings.divider_color }};
      {% if block.settings.divider_alignment == 'left' %}
        margin-left: 0;
        margin-right: auto;
      {% elsif block.settings.divider_alignment == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% else %}
        margin-left: 0;
        margin-right: 0;
      {% endif %}
    }
  {% endif %}

  .ai-stats-section__number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_font_size }}px;
    font-weight: {{ block.settings.number_font_weight }};
    line-height: 1.1;
    margin-bottom: {{ block.settings.number_label_gap }}px;
    {% if block.settings.number_style == 'gradient' %}
      background: linear-gradient({{ block.settings.number_gradient_angle }}deg, {{ block.settings.number_gradient_color_1 }}, {{ block.settings.number_gradient_color_2 }});
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    {% else %}
      color: {{ block.settings.number_color }};
    {% endif %}
    {% if block.settings.number_text_shadow %}
      text-shadow: {{ block.settings.shadow_offset_x }}px {{ block.settings.shadow_offset_y }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
    {% endif %}
  }

  .ai-stats-section__label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_font_size }}px;
    color: {{ block.settings.label_color }};
    font-weight: {{ block.settings.label_font_weight }};
    letter-spacing: {{ block.settings.label_letter_spacing }}px;
    margin-bottom: {{ block.settings.label_description_gap }}px;
  }

  .ai-stats-section__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    font-style: {{ block.settings.description_font_style }};
    margin-top: {{ block.settings.label_description_gap }}px;
  }

  .ai-stats-section__footer-{{ ai_gen_id }} {
    margin-top: {{ block.settings.footer_top_margin }}px;
    text-align: {{ block.settings.text_align_desktop }};
    display: flex;
    align-items: center;
    gap: 8px;
    {% if block.settings.text_align_desktop == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_align_desktop == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-stats-section__footer-icon-{{ ai_gen_id }} {
    width: {{ block.settings.footer_font_size }}px;
    height: {{ block.settings.footer_font_size }}px;
    flex-shrink: 0;
  }

  .ai-stats-section__footer-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.footer_color }};
  }

  .ai-stats-section__footer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.footer_font_size }}px;
    color: {{ block.settings.footer_color }};
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-stats-section__title-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_align_mobile }};
    }

    .ai-stats-section__item-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_align_mobile }};
    }

    .ai-stats-section__footer-{{ ai_gen_id }} {
      text-align: {{ block.settings.text_align_mobile }};
      {% if block.settings.text_align_mobile == 'center' %}
        justify-content: center;
      {% elsif block.settings.text_align_mobile == 'right' %}
        justify-content: flex-end;
      {% else %}
        justify-content: flex-start;
      {% endif %}
    }

    .ai-stats-section__number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_font_size }}px * 0.7);
    }

    .ai-stats-section__title-part1-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_part1_font_size }}px * 0.7);
    }

    .ai-stats-section__title-part2-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_part2_font_size }}px * 0.7);
    }
  }
{% endstyle %}

<div class="ai-stats-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-stats-section__inner-{{ ai_gen_id }}">
    {% if block.settings.title_part1 != blank or block.settings.title_part2 != blank %}
      <div class="ai-stats-section__title-{{ ai_gen_id }}">
        {% if block.settings.title_part1 != blank %}
          <h2 class="ai-stats-section__title-part1-{{ ai_gen_id }}">{{ block.settings.title_part1 }}</h2>
        {% endif %}
        {% if block.settings.title_part2 != blank %}
          <h2 class="ai-stats-section__title-part2-{{ ai_gen_id }}">{{ block.settings.title_part2 }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-stats-section__items-{{ ai_gen_id }}">
      {% for i in (1..block.settings.number_of_stats) %}
        {% assign stat_number_key = 'stat_' | append: i | append: '_number' %}
        {% assign stat_label_key = 'stat_' | append: i | append: '_label' %}
        {% assign stat_description_key = 'stat_' | append: i | append: '_description' %}
        {% assign stat_number_override_key = 'stat_' | append: i | append: '_number_color_override' %}
        {% assign stat_use_override_key = 'stat_' | append: i | append: '_use_color_override' %}

        {% assign stat_number = block.settings[stat_number_key] %}
        {% assign stat_label = block.settings[stat_label_key] %}
        {% assign stat_description = block.settings[stat_description_key] %}
        {% assign stat_number_override = block.settings[stat_number_override_key] %}
        {% assign stat_use_override = block.settings[stat_use_override_key] %}

        <div class="ai-stats-section__item-{{ ai_gen_id }}">
          {% if stat_number != blank %}
            <div 
              class="ai-stats-section__number-{{ ai_gen_id }}"
              {% if stat_use_override and block.settings.number_style == 'solid' %}
                style="color: {{ stat_number_override }};"
              {% endif %}
            >
              {{ stat_number }}
            </div>
          {% endif %}

          {% if stat_label != blank %}
            <div class="ai-stats-section__label-{{ ai_gen_id }}">
              {{ stat_label }}
            </div>
          {% endif %}

          {% if stat_description != blank %}
            <div class="ai-stats-section__description-{{ ai_gen_id }}">
              {{ stat_description }}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {% if block.settings.footer_text != blank %}
      <div class="ai-stats-section__footer-{{ ai_gen_id }}">
        {% if block.settings.show_footer_icon %}
          <div class="ai-stats-section__footer-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="16" x2="12" y2="12"></line>
              <line x1="12" y1="8" x2="12.01" y2="8"></line>
            </svg>
          </div>
        {% endif %}
        <div class="ai-stats-section__footer-text-{{ ai_gen_id }}">
          {{ block.settings.footer_text }}
        </div>
      </div>
    {% endif %}
  </div>
</div>

