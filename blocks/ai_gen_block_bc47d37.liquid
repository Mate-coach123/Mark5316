{% doc %}
  @prompt
    Create an image banner section with two separate image fields. The first image should display on desktop only, and the second image should display on mobile only. Each image should have individual width and height size controls so I can adjust how large the image appears on screen. The section should have an image overlay opacity slider. Images should be fully responsive and centered on their respective devices.
    , The section height should always automatically adjust to match the height of the displayed image, so there is no extra white space above or below. The section should never have a fixed height.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-responsive-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-responsive-banner__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-responsive-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    pointer-events: none;
    z-index: 1;
  }

  .ai-responsive-banner__desktop-{{ ai_gen_id }} {
    display: none;
  }

  .ai-responsive-banner__mobile-{{ ai_gen_id }} {
    display: block;
  }

  .ai-responsive-banner__desktop-{{ ai_gen_id }} img,
  .ai-responsive-banner__mobile-{{ ai_gen_id }} img {
    display: block;
    width: {{ block.settings.mobile_image_width }}%;
    height: auto;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    width: 100%;
    height: {{ block.settings.mobile_image_height }}px;
  }

  .ai-responsive-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-responsive-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .ai-responsive-banner__desktop-{{ ai_gen_id }} {
      display: block;
    }

    .ai-responsive-banner__mobile-{{ ai_gen_id }} {
      display: none;
    }

    .ai-responsive-banner__desktop-{{ ai_gen_id }} img {
      width: {{ block.settings.desktop_image_width }}%;
    }

    .ai-responsive-banner__placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.desktop_image_height }}px;
    }
  }
{% endstyle %}

<div class="ai-responsive-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-responsive-banner__image-wrapper-{{ ai_gen_id }}">
    <div class="ai-responsive-banner__desktop-{{ ai_gen_id }}">
      {% if block.settings.desktop_image %}
        <img
          src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
          alt="{{ block.settings.desktop_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.desktop_image.width }}"
          height="{{ block.settings.desktop_image.height }}"
        >
      {% else %}
        <div class="ai-responsive-banner__placeholder-{{ ai_gen_id }}" style="width: {{ block.settings.desktop_image_width }}%;">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-responsive-banner__empty-state-{{ ai_gen_id }}">
            Add a desktop image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-responsive-banner__mobile-{{ ai_gen_id }}">
      {% if block.settings.mobile_image %}
        <img
          src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
          alt="{{ block.settings.mobile_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.mobile_image.width }}"
          height="{{ block.settings.mobile_image.height }}"
        >
      {% else %}
        <div class="ai-responsive-banner__placeholder-{{ ai_gen_id }}" style="width: {{ block.settings.mobile_image_width }}%;">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-responsive-banner__empty-state-{{ ai_gen_id }}">
            Add a mobile image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-responsive-banner__overlay-{{ ai_gen_id }}"></div>
  </div>
</div>

{% schema %}
{
  "name": "Responsive image banner",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "range",
      "id": "desktop_image_width",
      "label": "Width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "desktop_image_height",
      "label": "Placeholder height",
      "min": 200,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "range",
      "id": "mobile_image_width",
      "label": "Width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "label": "Placeholder height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Responsive image banner"
    }
  ],
  "tag": null
}
{% endschema %}